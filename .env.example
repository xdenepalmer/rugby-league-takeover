# Supabase connection (optional overrides — safe defaults ship in
# src/api/supabaseClient.js; the publishable key is not a secret).
VITE_SUPABASE_URL=https://ohytlrgfpcpvnqgdpqap.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_key

# ---------------------------------------------------------------------------
# Edge Function secrets — set these in Supabase (Dashboard → Edge Functions →
# Secrets, or `supabase secrets set`), NEVER in frontend env.
# Full Stripe go-live checklist (webhook endpoint, events, test cards,
# refunds): docs/STRIPE_GO_LIVE.md
#
#   STRIPE_SECRET_KEY          Stripe secret key, LIVE mode (createCheckout, stripeWebhook,
#                               verifyCheckoutReturn, stripeRefund)
#   STRIPE_WEBHOOK_SECRET      Stripe webhook signing secret, LIVE mode (stripeWebhook)
#   STRIPE_MODE                Optional — "test" or "live" (default "live"). Set to "test"
#                               to route checkout through the *_TEST keys below instead.
#   STRIPE_SECRET_KEY_TEST     Stripe secret key, TEST mode (used when STRIPE_MODE=test)
#   STRIPE_WEBHOOK_SECRET_TEST Stripe webhook signing secret, TEST mode (a separate webhook
#                               endpoint pointed at Stripe test mode — see MIGRATION-SUPABASE.md)
#   STRIPE_SECRET_KEY_LIVE     Optional explicit alias for STRIPE_SECRET_KEY in live mode
#   STRIPE_WEBHOOK_SECRET_LIVE Optional explicit alias for STRIPE_WEBHOOK_SECRET in live mode
#   CHECKOUT_ALLOWED_ORIGINS   Comma-separated origins allowed for checkout redirects
#   CHECKOUT_DEFAULT_ORIGIN    Fallback checkout origin (default https://rugbyleaguetakeover.com)
#   RESEND_API_KEY             Optional — enables release-alert emails (notifyProductRelease)
#   EMAIL_FROM                 Optional — sender for Resend emails
#   SITE_URL                   Optional — public site URL used in emails
#   AUSPOST_API_KEY            AusPost API key (auspostRates, auspostCreateLabel, auspostTrack)
#   AUSPOST_ACCOUNT_NUMBER     AusPost MyPost Business account number (auspostCreateLabel only)
# ---------------------------------------------------------------------------
